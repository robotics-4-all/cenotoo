# MQTT bridge service account credentials.
# Used by:
#   - mosquitto-go-auth: validates the bridge superuser via cenotoo-api
#   - mqtt-bridge Deployment: MQTT_USERNAME / MQTT_PASSWORD env vars
#   - cenotoo-api Deployment: MQTT_BRIDGE_USERNAME / MQTT_BRIDGE_PASSWORD env vars
#
# The bridge service account bypasses per-project ACL checks and can
# subscribe to all topics. Choose a strong, unique password.
#
# To generate base64 values:
#   echo -n 'cenotoo-bridge' | base64
#   echo -n 'your-strong-password-here' | base64
#
# Override in production via sealed-secrets or external-secrets.
apiVersion: v1
kind: Secret
metadata:
  name: cenotoo-mqtt-credentials
  labels:
    app.kubernetes.io/component: mqtt-broker
    app.kubernetes.io/part-of: cenotoo
type: Opaque
data:
  # "cenotoo-bridge" base64-encoded — change username if desired
  username: Y2Vub3Rvby1icmlkZ2U=
  # "change-me-strong-password" base64-encoded — CHANGE IN PRODUCTION
  password: Y2hhbmdlLW1lLXN0cm9uZy1wYXNzd29yZA==
