# =============================================================================
# ECO-READY Infrastructure — Environment Configuration
# Copy to .env and customize per node: cp .env.example .env
# =============================================================================

# --- Kafka Brokers (same on both nodes) ---
KAFKA_BROKER1_IP=192.168.1.101
KAFKA_BROKER2_IP=192.168.1.102
KAFKA_CLUSTER_ID=  # Generate with: python scripts/generate-cluster-id.py

# --- Kafka Auth ---
KAFKA_USERNAME=admin
KAFKA_PASSWORD=CHANGE_ME
KAFKA_USER_PASSWORD=CHANGE_ME

# --- Cassandra (same on both nodes) ---
CASSANDRA_SEEDS=192.168.1.101,192.168.1.102
CASSANDRA_USERNAME=cassandra
CASSANDRA_PASSWORD=CHANGE_ME

# --- Node 1 specific (uncomment on Node 1) ---
CASSANDRA_BROADCAST_ADDRESS1=192.168.1.101

# --- Node 2 specific (uncomment on Node 2) ---
CASSANDRA_BROADCAST_ADDRESS2=192.168.1.102


# --- MQTT bridge service account (shared by mqtt-auth sidecar and mqtt-bridge) ---
MQTT_BRIDGE_USERNAME=cenotoo-bridge
MQTT_BRIDGE_PASSWORD=CHANGE_ME
MQTT_CLIENT_ID=cenotoo-bridge

# --- CoAP bridge ---
COAP_MAX_PAYLOAD_BYTES=1024
